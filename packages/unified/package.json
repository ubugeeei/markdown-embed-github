{
  "name": "@markdown-embed-github/unified",
  "version": "0.0.1",
  "description": "unified adapter for @markdown-embed-github/core",
  "keywords": [
    "embed",
    "github",
    "markdown",
    "permalink",
    "source",
    "unified"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter \"@markdown-embed-github/core\" run build",
    "build": "tsdown",
    "format": "oxfmt --write src test README.md package.json tsconfig.json tsdown.config.ts vitest.config.mjs",
    "format:check": "oxfmt --check src test README.md package.json tsconfig.json tsdown.config.ts vitest.config.mjs",
    "prelint": "pnpm --filter \"@markdown-embed-github/core\" run build",
    "lint": "oxlint --type-aware --type-check --import-plugin --node-plugin --vitest-plugin src test tsdown.config.ts vitest.config.mjs",
    "pretest": "pnpm --filter \"@markdown-embed-github/core\" run build",
    "test": "vitest run",
    "check": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@markdown-embed-github/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsdown": "^0.21.0",
    "typescript": "^5.6.3",
    "unified": "^11.0.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.12.3"
}
